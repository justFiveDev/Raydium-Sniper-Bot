# Copy to `.env` and fill in values. Never commit `.env`.

# --- HTTP server ---
PORT=5000
SESSION_SECRET=change-me-to-a-long-random-string

# `production` sets secure session cookies (HTTPS)
# NODE_ENV=production

# --- Solana ---
RPC_ENDPOINT=https://api.mainnet-beta.solana.com

# Yellowstone gRPC (Triton / etc.)
GRPC_ENDPOINT=
xToken=

# --- Optional dev / UI testing ---
# Set to 1 to enable “Load sample log lines” and POST /api/sniper/logs/sample
# ENABLE_SAMPLE_SNIPER_LOGS=1
